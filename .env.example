# Tenth Project — Environment Variables

# Supabase (optional for local dev — app uses local JSON store as fallback)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI — OpenAI or AIML API (optional — app uses smart fallback when not set)
OPENAI_API_KEY=sk-...
# OR use AIML API:
# AIML_API_KEY=your-aiml-key
# AIML_BASE_URL=https://api.aimlapi.com/v1
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_USER_ID=your-demo-supabase-user-uuid
